# Copy to .env and fill in your Neon project's endpoints. These are baked into
# release .app builds via `make desktop-build` / `make desktop-build-universal`.
# Not needed for `make desktop-dev`, which reads TOKI_NEON_*_URL env vars or the
# on-disk settings file instead.
NEON_AUTH_URL=
NEON_DATA_URL=

# Postgres owner connection string, used only to apply schema.sql (not read by
# the app). From the Neon console: Connection Details -> owner role.
NEON_DB_URL=
